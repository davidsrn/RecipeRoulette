# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TG_TOKEN=your_bot_token_here

# Your numeric Telegram User ID — get it from @userinfobot
AUTHORIZED_USER_ID=123456789

# ── Web App ───────────────────────────────────────────────────────────────────
# Password shown on the login page
APP_PASSWORD=your_password_here

# Random secret for signing session cookies (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_me_to_a_random_32_char_string

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite file (relative to project root)
DB_PATH=./recipes.db
